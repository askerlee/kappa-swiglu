#!/bin/bash
#PBS -N base_train
#PBS -q normal
#PBS -P 11610002
#PBS -l select=1:ngpus=1
#PBS -l walltime=24:00:00

export PYTHONUNBUFFERED=1
export NANOCHAT_BASE_DIR=output
export BASE_TRAIN_EXTRA_ARGS="$@"

cd "$PBS_O_WORKDIR" || exit 1
exec > "pbs-${PBS_JOBID}.out" 2> "pbs-${PBS_JOBID}.err"

python -m scripts.base_train --save-every 8889 --model-tag "$PBS_JOBID" "$@"